{
	"name": "playwright-report-summary",
	"description": "A GitHub action to report Playwright test results as pull-request comments",
	"version": "4.0.0",
	"author": "Philipp Daun <daun@daun.ltd>",
	"homepage": "https://github.com/daun/playwright-report-summary",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/daun/playwright-report-summary.git"
	},
	"bugs": {
		"url": "https://github.com/daun/playwright-report-summary/issues"
	},
	"keywords": [
		"actions",
		"node",
		"testing",
		"reporting",
		"test report",
		"playwright",
		"pull request"
	],
	"exports": {
		".": "./dist/index.js"
	},
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"bundle": "npm run format:write && npm run package",
		"format:write": "prettier --write '**/*.ts'",
		"format:check": "prettier --check '**/*.ts'",
		"lint": "eslint .",
		"package": "rimraf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
		"package:watch": "npm run package -- --watch",
		"test": "jest",
		"test:update": "jest -u",
		"all": "npm run format:write && npm run lint && npm run test && npm run package"
	},
	"license": "MIT",
	"dependencies": {
		"@actions/core": "^3.0.1",
		"@actions/github": "^9.1.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@octokit/openapi-types": "^27.0.0",
		"@playwright/test": "^1.58.2",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.9.1",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"eslint": "^9.39.4",
		"eslint-plugin-github": "^6.0.0",
		"eslint-plugin-jest": "^29.15.2",
		"eslint-plugin-jsonc": "^3.1.2",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.6.0",
		"jest": "^30.2.0",
		"js-yaml": "^4.1.1",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"rollup": "^4.59.0",
		"ts-jest": "^29.4.6",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4"
	}
}
